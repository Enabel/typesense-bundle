{
    "name": "enabel/typesense",
    "description": "Typesense search integration with attribute-based document mapping",
    "license": "MIT",
    "type": "library",
    "keywords": ["typesense", "search"],
    "require": {
        "php": ">=8.4",
        "typesense/typesense-php": "^4.9 || ^5.2",
        "symfony/cache-contracts": "^3.0"
    },
    "require-dev": {
        "doctrine/orm": "^3.6",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.0",
        "symfony/console": "^8.0",
        "symfony/framework-bundle": "^8.0",
        "symfony/http-client": "^8.0"
    },
    "suggest": {
        "doctrine/orm": "Required for Doctrine integration (^3.0)",
        "symfony/framework-bundle": "Required for Symfony bundle integration (^7.0)",
        "symfony/console": "Required for console commands (^7.0)"
    },
    "autoload": {
        "psr-4": {
            "Enabel\\Typesense\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Enabel\\Typesense\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
